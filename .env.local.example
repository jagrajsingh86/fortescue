# Required — Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIza...

# Optional: override the model (defaults to gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.5-flash

# Optional — Vercel KV / Upstash for shareable saved reports.
# On Vercel: Storage → Create → KV. These are auto-injected on deploy.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
